generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  emails        Email[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Trackio Models ──────────────────────────────────────────

model Email {
  id          String      @id @default(cuid())
  recipient   String
  subject     String
  status      String      @default("sent")
  openCount   Int         @default(0)
  senderEmail String
  senderToken String?     // Token used by extension to authenticate self-view reports
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  openEvents  OpenEvent[]

  @@index([senderEmail])
  @@index([userId])
}

model OpenEvent {
  id         String   @id @default(cuid())
  emailId    String
  email      Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  timestamp  DateTime @default(now())
  ipAddress  String?
  userAgent  String?
  isSelfOpen Boolean  @default(false) // Marked true by extension self-view reports

  @@index([emailId])
}
