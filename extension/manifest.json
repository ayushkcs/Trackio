{
  "manifest_version": 3,
  "name": "Trackio - Email Open Tracker",
  "description": "Track when your Gmail emails are opened with real-time notifications and analytics.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "activeTab",
    "notifications",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:3000/*",
    "https://*.ayushk.blog/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
